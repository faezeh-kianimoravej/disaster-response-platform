{
  "family": "kafka",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "2048",
  "executionRoleArn": "arn:aws:iam::484069698104:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "kafka",
      "image": "confluentinc/cp-kafka:7.5.0",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 9092,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "KAFKA_BROKER_ID", "value": "1" },
        { "name": "KAFKA_ZOOKEEPER_CONNECT", "value": "zookeeper.drccs.local:2181" },
        { "name": "KAFKA_LISTENERS", "value": "PLAINTEXT://0.0.0.0:9092" },
        { "name": "KAFKA_ADVERTISED_LISTENERS", "value": "PLAINTEXT://kafka.drccs.local:9092" },
        { "name": "KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR", "value": "1" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/kafka",
          "awslogs-region": "eu-north-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
      ,
      "healthCheck": {
        "command": ["CMD-SHELL", "nc -z localhost 9092"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 30
      }
    }
  ]
}
