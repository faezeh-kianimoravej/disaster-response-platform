package nl.saxion.disaster.notification_service.integration;

import io.restassured.RestAssured;
import io.restassured.http.ContentType;
import net.jqwik.api.Arbitrary;
import net.jqwik.api.Arbitraries;
import nl.saxion.disaster.notification_service.config.TestContainersConfig;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import org.springframework.boot.test.context.SpringBootTest;
import org.springframework.boot.test.web.server.LocalServerPort;
import org.springframework.context.annotation.Import;
import org.springframework.test.context.ActiveProfiles;

import static net.jqwik.api.Arbitraries.integers;
import static net.jqwik.api.Arbitraries.strings;

import static io.restassured.RestAssured.given;
import static org.hamcrest.Matchers.*;

/**
 * Integration Tests for Notification Controller REST API Contracts
 * 
 * Validates that the API endpoints adhere to the constraints defined in
 * ADR_REST_Endpoint_Standards:
 * - HTTP status codes for success/failure cases
 * - Request/response schema invariants
 * - Field constraints (e.g., message content, valid recipients)
 * - Notification delivery rules and timing constraints
 * 
 * NOTE: Uses @SpringBootTest with TestContainers PostgreSQL for realistic DB testing.
 * The test profile disables external dependencies (Eureka, Kafka).
 * Container is reused across tests for performance.
 */
@Tag("integration")
@SpringBootTest(
    webEnvironment = SpringBootTest.WebEnvironment.RANDOM_PORT
)
@Import(TestContainersConfig.class)
@ActiveProfiles("test")
class NotificationControllerIntegrationTest {

    @LocalServerPort
    private int port;

    @BeforeEach
    void setUp() {
        RestAssured.port = port;
        RestAssured.basePath = "/api/notifications";
    }

    /**
     * Property: Creating a notification with valid data should return 201.
     * 
     * Tests that valid notification creation consistently produces success.
     */
    @Test
    void createNotificationWithValidData_shouldReturn201() {
        Arbitrary<String> messages = strings().alpha().ofMinLength(1).ofMaxLength(500);
        Arbitrary<String> types = Arbitraries.of("ALERT", "INFO", "WARNING", "CRITICAL");
        Arbitrary<Long> recipientIds = Arbitraries.longs().between(1L, 1000L);
        
        messages.flatMap(message -> 
            types.flatMap(type -> 
                recipientIds.map(recipientId -> new Object[]{message, type, recipientId})
            )
        ).sampleStream().limit(20).forEach(params -> {
            String message = (String) params[0];
            String type = (String) params[1];
            Long recipientId = (Long) params[2];
            
            String payload = createNotificationPayload(message, type, recipientId);
            
            given()
                .contentType(ContentType.JSON)
                .body(payload)
            .when()
                .post("/")
            .then()
                .statusCode(anyOf(
                    equalTo(201),  // Created
                    equalTo(400),  // Bad request
                    equalTo(404)   // Recipient not found
                ));
        });
    }

    /**
     * Property: GET /notifications/{id} should return 200 or 404 for any ID.
     * 
     * Validates that querying notifications never crashes regardless of ID.
     */
    @Test
    void getNotification_withValidId_shouldReturn200Or404() {
        integers().between(1, 1000).sampleStream().limit(20).forEach(id -> {
            given()
            .when()
                .get("/{id}", id)
            .then()
                .statusCode(anyOf(
                    equalTo(200),  // Found
                    equalTo(404)   // Not found
                ))
                .body(notNullValue());
        });
    }

    /**
     * Property: Creating notification with message exceeding max length should fail validation.
     * 
     * Tests constraint validation on field length.
     */
    @Test
    void createNotificationWithInvalidMessage_shouldFailValidation() {
        strings().alpha().ofMinLength(501).ofMaxLength(1000).sampleStream().limit(20).forEach(longMessage -> {
            String payload = createNotificationPayload(longMessage, "ALERT", 1L);
            
            given()
                .contentType(ContentType.JSON)
                .body(payload)
            .when()
                .post("/")
            .then()
                .statusCode(anyOf(
                    equalTo(400),  // Bad request
                    equalTo(422)   // Unprocessable entity
                ));
        });
    }

    /**
     * Property: Marking notification as read should return 200 or 404.
     * 
     * Tests notification state transitions.
     */
    @Test
    void markNotificationAsRead_shouldReturn200Or404() {
        integers().between(1, 1000).sampleStream().limit(20).forEach(notificationId -> {
            given()
                .contentType(ContentType.JSON)
                .body("{\"read\":true}")
            .when()
                .put("/{id}", notificationId)
            .then()
                .statusCode(anyOf(
                    equalTo(200),  // OK
                    equalTo(404)   // Not found
                ));
        });
    }

    /**
     * Helper: Generate JSON payload for notification creation.
     */
    private String createNotificationPayload(String message, String type, Long recipientId) {
        return String.format(
            "{\"message\":\"%s\",\"type\":\"%s\",\"recipientId\":%d}",
            escapeJson(message),
            type,
            recipientId
        );
    }

    /**
     * Helper: Escape JSON strings.
     */
    private String escapeJson(String str) {
        return str.replace("\"", "\\\"")
                  .replace("\n", "\\n")
                  .replace("\r", "\\r");
    }
}
